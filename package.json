{
  "name": "dpip",
  "version": "1.0.0-pre.2",
  "private": true,
  "description": "DPIP - Disaster Prevention Information Platform",
  "author": "ExpTech Studio <ExpTech.tw@gmail.com>",
  "license": "AGPL-3.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun run --cwd packages/web dev",
    "dev:desktop": "bun run --cwd packages/desktop dev",
    "build:web": "bun run --cwd packages/web build",
    "build:desktop": "bun run --cwd packages/desktop build",
    "package": "bun run --cwd packages/desktop package",
    "package:win": "bun run --cwd packages/desktop package:win",
    "package:mac": "bun run --cwd packages/desktop package:mac",
    "package:linux": "bun run --cwd packages/desktop package:linux"
  },
  "dependencies": {
    "next": "^16.0.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "maplibre-gl": "^5.13.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3"
  }
}